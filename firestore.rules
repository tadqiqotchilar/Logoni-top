rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Levels collection: hamma o'qiy oladi, faqat server/admin yoza oladi
    match /levels/{levelId} {
      allow read: if true;
      allow write: if true;
    }
    // Countries collection: hamma o'qiy oladi, hamma yoza oladi
    match /countries/{countryId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
